<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<PropertyGroup>
		<CurrentAbsolutePath>$(MSBuildThisFileDirectory)</CurrentAbsolutePath>
		<ThirdPartyAbsolutePath>$([System.IO.Path]::Combine('$(MSBuildThisFileDirectory)', '../../third_party/onnx/onnx'))</ThirdPartyAbsolutePath>
		<ProtobufOutputAbsolutePath>$([System.IO.Path]::Combine('$(MSBuildThisFileDirectory)', 'Protobuf'))</ProtobufOutputAbsolutePath>
		<ProtobufOutputTargetAbsolutePath>$([System.IO.Path]::Combine('$(ProtobufOutputAbsolutePath)', 'OnnxMl.cs'))</ProtobufOutputTargetAbsolutePath>
	</PropertyGroup>

	<Target Name="PreBuild" BeforeTargets="PreBuildEvent" Condition="!Exists('$(ProtobufOutputTargetAbsolutePath)')">
		<MakeDir Directories="$(ProtobufOutputAbsolutePath)" Condition="!Exists('$(ProtobufOutputAbsolutePath)')" />
		<Exec Command="protoc --proto_path=$(ThirdPartyAbsolutePath) --csharp_out=$(ProtobufOutputAbsolutePath) $(ThirdPartyAbsolutePath)/onnx-ml.proto3" />
	</Target>

	<ItemGroup>
		<PackageReference Include="Google.Protobuf" Version="3.34.0" />
	</ItemGroup>

</Project>
